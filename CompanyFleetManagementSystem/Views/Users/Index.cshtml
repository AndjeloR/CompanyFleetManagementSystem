@model IEnumerable<CompanyFleetManagementSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "Управление на потребители";
}

<h2>Списък с потребители</h2>

<table class="table" border="1" style="width:100%; border-collapse: collapse;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th>Email</th>
            <th>Текуща Роля</th>
            <th>Промяна на роля</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td><strong>@user.RoleName</strong></td>
                <td>
                    <form asp-controller="Users" asp-action="ChangeRole" method="post" style="display:inline;">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <select name="newRole">
                            <option value="Driver">Driver</option>
                            <option value="Dispatcher">Dispatcher</option>
                            <option value="Administrator">Administrator</option>
                        </select>
                        <button type="submit">Запази</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>