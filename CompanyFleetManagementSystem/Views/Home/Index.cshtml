@{
    ViewData["Title"] = "Начало";
}

<div class="text-center" style="padding: 50px; background-color: #f8f9fa; border-radius: 15px; margin-top: 20px;">
    <h1 class="display-4" style="color: #2c3e50; font-weight: bold;">Система за управление на автопарк "Коноконо"</h1>
    <p class="lead">Добре дошли в централизираната платформа за логистика и управление на рейсове.</p>
    <hr style="width: 50%; margin: 20px auto;">

    @if (!User.Identity.IsAuthenticated)
    {
        <div style="margin-top: 30px;">
            <p>Моля, влезте в профила си, за да управлявате вашите задачи.</p>
            <a href="/Identity/Account/Login" style="background-color: #007bff; color: white; padding: 10px 25px; text-decoration: none; border-radius: 5px; margin-right: 10px;">Вход</a>
            <a href="/Identity/Account/Register" style="background-color: #6c757d; color: white; padding: 10px 25px; text-decoration: none; border-radius: 5px;">Регистрация</a>
        </div>
    }
    else
    {
        <div style="margin-top: 30px; display: flex; justify-content: center; gap: 20px;">
            <div style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; width: 250px; background: white;">
                <h3>Рейсове</h3>
                <p>Преглед на всички графици и маршрути.</p>
                <a href="/Trips" style="color: #007bff;">Към рейсовете →</a>
            </div>

            @if (User.IsInRole("Dispatcher") || User.IsInRole("Administrator"))
            {
                <div style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; width: 250px; background: white; border-top: 5px solid #28a745;">
                    <h3>Управление</h3>
                    <p>Създаване и редакция на нови рейсове.</p>
                    <a href="/Trips/Create" style="color: #28a745; font-weight: bold;">+ Нов Рейс</a>
                </div>
            }

            @if (User.IsInRole("Driver"))
            {
                <div style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; width: 250px; background: white;">
                    <h3>Моите задачи</h3>
                    <p>Вижте зачислените на Вас курсове.</p>
                    <a href="/Trips/MyTrips" style="color: #007bff;">Към моите рейсове →</a>
                </div>
            }

            @if (User.IsInRole("Administrator"))
            {
                <div style="padding: 20px; border: 1px solid #ddd; border-radius: 10px; width: 250px; background: white;">
                    <h3>Потребители</h3>
                    <p>Управление на роли и персонал.</p>
                    <a href="/Users" style="color: #007bff;">Към администрация →</a>
                </div>
            }
        </div>
    }
</div>